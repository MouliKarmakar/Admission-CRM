{
  "compilerOptions": {
    "target": "ES2020",                                  /* Fixes padStart and Object.values */
    "lib": ["ES2020"],                                   /* Tells TS which JS features are available */
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": "./src",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "types": ["node"],                                   /* Fixes 'process', 'path', and '__dirname' */
    "moduleResolution": "node"                           /* Helps TS find your installed packages */
  },
  "include": ["src/**/*", "prisma/seed.ts"]
}